// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "claude-acp": {
      "favorite_config_option_values": {
        "effort": [
          "medium"
        ]
      },
      "type": "registry"
    }
  },
  "helix_mode": false,
  "bottom_dock_layout": "contained",
  "tab_bar": {
    "show": true
  },
  "title_bar": {
    "show_onboarding_banner": true,
    "show_project_items": true,
    "show_branch_name": true
  },
  "debugger": {
    "button": false
  },
  "search": {
    "button": false
  },
  "diagnostics": {
    "button": true
  },
  "status_bar": {
    "cursor_position_button": true,
    "active_encoding_button": "non_utf8",
    "active_language_button": false
  },
  "project_panel": {
    "button": true,
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "ssh_connections": [
    {
      "host": "compute",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/abragante"
          ]
        }
      ],
      "port_forwards": [
        {
          "local_port": 7860,
          "remote_port": 7860
        }
      ]
    },
    {
      "host": "airflow",
      "username": "mranzetti",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/mranzetti"
          ]
        }
      ]
    }
  ],
  "use_on_type_format": true,
  "ensure_final_newline_on_save": true,
  "format_on_save": "off",
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Latte"
  },
  "edit_predictions": {},
  "show_edit_predictions": false,
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "default_model": {
      "enable_thinking": true,
      "provider": "google",
      "model": "gemini-2.5-flash",
    },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vim_mode": true,
  "base_keymap": "Atom",
  "ui_font_size": 14,
  "relative_line_numbers": "enabled",
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "always",
    "use_multiline_find": true,
  },
  "toolbar": {
    "code_actions": false,
    "agent_review": false,
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "preferred_line_length": 150,
  "soft_wrap": "preferred_line_length",
  "use_autoclose": true,
  "git": {
    "inline_blame": {
      "enabled": true,
      "delay_ms": 100,
    },
  },
  "outline_panel": {
    "dock": "left",
    "button": false,
  },
  "terminal": {
    "alternate_scroll": "off",
    "blinking": "terminal_controlled",
    "copy_on_select": true,
    "font_family": "DaddyTimeMono Nerd Font",
    "line_height": "standard",
    "working_directory": "current_project_directory",
    "button": false,
  },
  "notification_panel": {
    "button": false,
  },
  "buffer_font_size": 16.0,
  "buffer_font_family": "DaddyTimeMono Nerd Font",
  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "One Dark"
  },
  "lsp": {
    "eslint": {
      "settings": {
        "run": "onSave",
        "lintTask": {
          "enable": true,
        },
      },
    },
    "vtsls": {
      "settings": {
        "typescript": {
          "preferences": {
            "importModuleSpecifier": "non-relative",
            "importModuleSpecifierEnding": "auto",
          },
        },
        "javascript": {
          "preferences": {
            "importModuleSpecifier": "non-relative",
            "importModuleSpecifierEnding": "auto",
          },
        },
      },
    },
    "pylsp": {
      "settings": {
        "plugins": {
          "mypy": {
            "enabled": true,
          },
          "pycodestyle": {
            "enabled": false,
          },
        },
      },
    },
  },
  "languages": {
    "Python": {
      "language_servers": ["ruff", "ty"],
      "format_on_save": "on",
      "formatter": [
        {
          "code_action": "source.organizeImports.ruff",
        },
        {
          "code_action": "source.fixAll.ruff",
        },
        {
          "language_server": {
            "name": "ruff",
          },
        },
      ],
    },
  },
}
