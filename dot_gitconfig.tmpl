[user]
	name = Andrea Bragante
	email = andrea.bragante@proton.me

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    dark = true
    features = colibri

[merge]
    conflictStyle = zdiff3

{{ if eq .chezmoi.os "darwin" -}}
[include]
    path = /opt/homebrew/share/git-delta/themes.gitconfig
{{ end -}}
